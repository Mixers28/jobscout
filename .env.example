# Core runtime
JOBSCOUT_APP_ENV=dev
JOBSCOUT_DATABASE_URL=sqlite+pysqlite:///./jobscout.db
JOBSCOUT_REDIS_URL=redis://localhost:6379/0

# Canonical artifact paths
JOBSCOUT_SKILLS_PROFILE_PATH=skills_profile.json
JOBSCOUT_TRUTH_BANK_PATH=truth_bank.yml
JOBSCOUT_SCORING_WEIGHTS_PATH=scoring_weights.yml
JOBSCOUT_RUBRIC_PATH=RUBRIC.md
JOBSCOUT_PROMPT_GUARDRAIL_PATH=prompt_guardrail.md

# Scheduler
JOBSCOUT_SCHEDULER_INTERVAL_SECONDS=86400
JOBSCOUT_SCHEDULER_MAX_RETRIES=2
JOBSCOUT_SCHEDULER_BACKOFF_SECONDS=2

# Notification rules
JOBSCOUT_NOTIFICATION_TOP_N=5
JOBSCOUT_NOTIFICATION_SCORE_THRESHOLD=80.0
JOBSCOUT_NOTIFICATION_LOOKBACK_HOURS=24

# Discord webhook (recommended primary channel)
JOBSCOUT_DISCORD_WEBHOOK_URL=

# Optional SMTP fallback channel
JOBSCOUT_SMTP_HOST=
JOBSCOUT_SMTP_PORT=25
JOBSCOUT_SMTP_USERNAME=
JOBSCOUT_SMTP_PASSWORD=
JOBSCOUT_SMTP_USE_TLS=false
JOBSCOUT_NOTIFICATION_EMAIL_FROM=
JOBSCOUT_NOTIFICATION_EMAIL_TO=

# IMAP polling — set these to auto-fetch job-alert emails from a Gmail mailbox.
# 1. Create a dedicated Gmail account (e.g. jobscout.alerts@gmail.com)
# 2. Enable 2-Step Verification, then generate an App Password (Google Account > Security > App Passwords)
# 3. Forward job alerts from Reed/Adzuna/LinkedIn to this address
# 4. Fill in the credentials below; leave JOBSCOUT_IMAP_HOST blank to disable
JOBSCOUT_IMAP_HOST=imap.gmail.com
JOBSCOUT_IMAP_PORT=993
JOBSCOUT_IMAP_USERNAME=
JOBSCOUT_IMAP_PASSWORD=
JOBSCOUT_IMAP_USE_SSL=true
JOBSCOUT_IMAP_MAILBOX=INBOX
JOBSCOUT_IMAP_MAX_FETCH=50
